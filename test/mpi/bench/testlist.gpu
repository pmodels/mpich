# performance tests are performed for (senddev, recvdev) \in {host, device}^2
# p2p_latency and p2p_bw is compared with ch4:ofi and --with-cuda on gpu_new

# latency tests
p2p_latency 2 arg=-senddev=host arg=-recvdev=host resultTest=TestBench
p2p_latency 2 arg=-senddev=host arg=-recvdev=device resultTest=TestBench
p2p_latency 2 arg=-senddev=device arg=-recvdev=host resultTest=TestBench
p2p_latency 2 arg=-senddev=device arg=-recvdev=device resultTest=TestBench

# bw tests
p2p_bw 2 arg=-senddev=host arg=-recvdev=host resultTest=TestBench
p2p_bw 2 arg=-senddev=host arg=-recvdev=device resultTest=TestBench
p2p_bw 2 arg=-senddev=device arg=-recvdev=host resultTest=TestBench
p2p_bw 2 arg=-senddev=device arg=-recvdev=device resultTest=TestBench
